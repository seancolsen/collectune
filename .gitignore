# Generated by Cargo
# will have compiled files and executables
/target/
backend/target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
# Cargo.lock is checked in for the backend executable

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by `trunk build` — embedded into the production binary at build time.
# The .gitkeep placeholder keeps the directory present so `rust-embed` doesn't
# fail before the first trunk build on a fresh checkout.
/frontend/dist/*
!/frontend/dist/.gitkeep
